{
  "name": "collectly-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_ENV=test jest --forceExit --detectOpenHandles --runInBand",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --forceExit",
    "test:e2e": "cypress run --headless",
    "test:e2e:open": "cypress open",
    "test:load": "artillery run load-tests/api-load.yml",
    "test:load:report": "artillery run --output load-tests/report.json load-tests/api-load.yml && artillery report load-tests/report.json",
    "lint": "eslint src --ext .js --max-warnings 0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ],
    "testTimeout": 120000
  },
  "mongodbMemoryServer": {
    "version": "7.0.14",
    "downloadDir": "./node_modules/.cache/mongodb-memory-server"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/s3-request-presigner": "^3.893.0",
    "@logtail/node": "^0.5.8",
    "@logtail/winston": "^0.5.8",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.43.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^2.1.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.1",
    "twilio": "^5.13.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.12.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^9.4.1",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
