# ─────────────────────────────────────────────────────────────────────────────
# Collectly Backend — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/collectly?retryWrites=true&w=majority

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
PER_USER_RATE_LIMIT_MAX=300

# ── Account Security ──────────────────────────────────────────────────────────
# Minutes an account stays locked after 5 failed login attempts (default: 15).
ACCOUNT_LOCKOUT_MINUTES=15

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_STARTER_PRICE_ID=price_your_starter_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# ── SendGrid (Email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourcollectlydomain.com
SENDGRID_FROM_NAME=Collectly
SENDGRID_WEBHOOK_VERIFY_KEY=

# ── Twilio (SMS + WhatsApp) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# ── Plivo (SMS fallback) ──────────────────────────────────────────────────────
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=

# ── Meta WhatsApp Business API ────────────────────────────────────────────────
META_WABA_TOKEN=
META_PHONE_NUMBER_ID=

# ── AWS S3 (Invoice Attachments) ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-collectly-attachments-bucket

# ── Encryption ────────────────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=replace_with_dedicated_64_char_random_hex

# ── Webhook Signing ───────────────────────────────────────────────────────────
# HMAC-SHA256 key for signing outgoing webhooks — must differ from JWT secrets.
WEBHOOK_SIGNING_SECRET=replace_with_dedicated_64_char_random_hex

# ── Sentry (Error Monitoring) ─────────────────────────────────────────────────
SENTRY_DSN=

# ── Automatic Reminder Scheduler ─────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=300000
SCHEDULER_BATCH_SIZE=100

# ── Notification Retry Scheduler ─────────────────────────────────────────────
NOTIFICATION_RETRY_MS=600000
NOTIFICATION_RETRY_BATCH=50

# ── Compliance & GDPR ─────────────────────────────────────────────────────────
UNSUBSCRIBE_SECRET=replace_with_dedicated_64_char_random_hex

# ── Redis (Queue & Caching) ───────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# ── Log Aggregation (Logtail / BetterStack) ───────────────────────────────────
LOGTAIL_TOKEN=

# ── Seed Admin (run once manually, never in CI) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@collectly.dev
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Platform Admin