# ─────────────────────────────────────────────────────────────────────────────
# Collectly Backend — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Required. MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/collectly?retryWrites=true&w=majority

# ── Frontend ──────────────────────────────────────────────────────────────────
# Required. Used for CORS, OAuth redirects, and reset/verify email links.
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required. Use long, random, unique secrets. Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Optional. Leave blank to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth ───────────────────────────────────────────────────────────
# Optional. Leave blank to disable Microsoft login.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Required for billing. Use sk_test_* keys in development.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_STARTER_PRICE_ID=price_your_starter_price_id
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# ── SendGrid (Email) ──────────────────────────────────────────────────────────
# Required for email delivery. Leave blank to run in simulated mode.
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourcollectlydomain.com
SENDGRID_FROM_NAME=Collectly

# ── Twilio (SMS + WhatsApp) ───────────────────────────────────────────────────
# Required for SMS/WhatsApp delivery. Leave blank to run in simulated mode.
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
# Optional. Required only for WhatsApp channel.
TWILIO_WHATSAPP_NUMBER=+1234567890

# ── AWS S3 (Invoice Attachments) ──────────────────────────────────────────────
# Required for PDF attachment upload. Leave blank to disable attachment feature.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-collectly-attachments-bucket

# ── Encryption ────────────────────────────────────────────────────────────────
# Required. Dedicated key for encrypting sensitive DB fields (e.g. 2FA secrets).
# MUST be different from JWT_ACCESS_SECRET — rotating JWT keys must not break 2FA.
# Generate with: openssl rand -hex 64
APP_ENCRYPTION_KEY=replace_with_dedicated_64_char_random_hex

# ── Sentry (Error Monitoring) ─────────────────────────────────────────────────
# Optional. Leave blank to disable error monitoring.
# Get your DSN from https://sentry.io
SENTRY_DSN=

# ── Automatic Reminder Scheduler ─────────────────────────────────────────────
# Set SCHEDULER_ENABLED=false to disable automatic batch processing.
# SCHEDULER_INTERVAL_MS: how often the batch runs (default: 300000 = 5 minutes)
# SCHEDULER_BATCH_SIZE: max invoices processed per run (default: 100)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=300000
SCHEDULER_BATCH_SIZE=100

# ── Compliance & GDPR ─────────────────────────────────────────────────────────
# Used for generating tamper-proof unsubscribe tokens.
# If not set, falls back to JWT_ACCESS_SECRET (not recommended for production).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
UNSUBSCRIBE_SECRET=replace_with_dedicated_64_char_random_hex